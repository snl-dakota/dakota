      [ expand_threshold {N_mdm(Real,trustRegionExpandTrigger)} ]
      [ contraction_factor {N_mdm(Real,trustRegionContract)} ]
      [ expansion_factor {N_mdm(Real,trustRegionExpand)} ]
     ]
    [ max_iterations {N_mdm(sizet,maxIterations)} ]
    [ convergence_tolerance {N_mdm(Real,convergenceTolerance)} ]
