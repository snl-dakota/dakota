      [ categorical {N_vam(categorical,discreteUncSetIntCat)} ]
      [ initial_point {N_vam(ivec,discreteUncSetIntVars)} ]
      [ descriptors {N_vae(deuilbl,DEUIVar_set_int)} ]
     ]
    [ string {N_vam(sizet,numDiscreteUncSetStrVars)}
      [ elements_per_variable {N_vam(newiarray,Var_Info_nduss)} ]
      elements {N_vam(newsarray,Var_Info_duss)}
      [ set_probabilities {N_vam(newrvec,Var_Info_DSSp)} ]
      [ initial_point {N_vam(strL,discreteUncSetStrVars)} ]
      [ descriptors {N_vae(deuslbl,DEUSVar_set_str)} ]
     ]
    [ real {N_vam(sizet,numDiscreteUncSetRealVars)}
      [ elements_per_variable {N_vam(newiarray,Var_Info_ndusr)} ]
      elements {N_vam(newrvec,Var_Info_dusr)}
      [ set_probabilities {N_vam(newrvec,Var_Info_DSRp)} ]
      [ categorical {N_vam(categorical,discreteUncSetRealCat)} ]
      [ initial_point {N_vam(rvec,discreteUncSetRealVars)} ]
      [ descriptors {N_vae(deurlbl,DEURVar_set_real)} ]
     ]
   ]
  [ continuous_state {N_vam(sizet,numContinuousStateVars)}
    [ initial_state {N_vam(rvec,continuousStateVars)} ]
    [ lower_bounds {N_vam(rvec,continuousStateLowerBnds)} ]
    [ upper_bounds {N_vam(rvec,continuousStateUpperBnds)} ]
    [ descriptors {N_vam(strL,continuousStateLabels)} ]
   ]
  [ discrete_state_range {N_vam(sizet,numDiscreteStateRangeVars)}
    [ initial_state {N_vam(ivec,discreteStateRangeVars)} ]
    [ lower_bounds {N_vam(ivec,discreteStateRangeLowerBnds)} ]
    [ upper_bounds {N_vam(ivec,discreteStateRangeUpperBnds)} ]
    [ descriptors {N_vam(strL,discreteStateRangeLabels)} ]
   ]
  [ discrete_state_set {0}
    [ integer {N_vam(sizet,numDiscreteStateSetIntVars)}
      [ elements_per_variable {N_vam(newiarray,Var_Info_ndssi)} ]
      elements {N_vam(newivec,Var_Info_dssi)}
      [ categorical {N_vam(categorical,discreteStateSetIntCat)} ]
      [ initial_state {N_vam(ivec,discreteStateSetIntVars)} ]
      [ descriptors {N_vam(strL,discreteStateSetIntLabels)} ]
     ]
    [ string {N_vam(sizet,numDiscreteStateSetStrVars)}
      [ elements_per_variable {N_vam(newiarray,Var_Info_ndsss)} ]
      elements {N_vam(newsarray,Var_Info_dsss)}
      [ initial_state {N_vam(strL,discreteStateSetStrVars)} ]
      [ descriptors {N_vam(strL,discreteStateSetStrLabels)} ]
     ]
    [ real {N_vam(sizet,numDiscreteStateSetRealVars)}
      [ elements_per_variable {N_vam(newiarray,Var_Info_ndssr)} ]
      elements {N_vam(newrvec,Var_Info_dssr)}
      [ categorical {N_vam(categorical,discreteStateSetRealCat)} ]
      [ initial_state {N_vam(rvec,discreteStateSetRealVars)} ]
      [ descriptors {N_vam(strL,discreteStateSetRealLabels)} ]
     ]
   ]
  [ linear_inequality_constraint_matrix {N_vam(rvec,linearIneqConstraintCoeffs)} ]
  [ linear_inequality_lower_bounds {N_vam(rvec,linearIneqLowerBnds)} ]
  [ linear_inequality_upper_bounds {N_vam(rvec,linearIneqUpperBnds)} ]
  [ linear_inequality_scale_types {N_vam(strL,linearIneqScaleTypes)} ]
  [ linear_inequality_scales {N_vam(rvec,linearIneqScales)} ]
  [ linear_equality_constraint_matrix {N_vam(rvec,linearEqConstraintCoeffs)} ]
  [ linear_equality_targets {N_vam(rvec,linearEqTargets)} ]
  [ linear_equality_scale_types {N_vam(strL,linearEqScaleTypes)} ]
  [ linear_equality_scales {N_vam(rvec,linearEqScales)} ]

KEYWORD interface {N_ifm3(start,0,stop)}
  [ id_interface {N_ifm(str,idInterface)} ]
  [ analysis_drivers {N_ifm(strL,analysisDrivers)}
    [ input_filter {N_ifm(str,inputFilter)} ]
    [ output_filter {N_ifm(str,outputFilter)} ]
    ( system {N_ifm(type,interfaceType_SYSTEM_INTERFACE)}
      [ parameters_file {N_ifm(str,parametersFile)} ]
      [ results_file {N_ifm(str,resultsFile)} ]
      [ parameters_format {N_ifm(type,parametersFileFormat_PARAMETERS_FILE_STANDARD)}
        standard {N_ifm(type,parametersFileFormat_PARAMETERS_FILE_STANDARD)}
        |
        aprepro {N_ifm(type,parametersFileFormat_PARAMETERS_FILE_APREPRO)}
        |
        json {N_ifm(type,parametersFileFormat_PARAMETERS_FILE_JSON)}
       ]
      [ results_format {N_ifm(type,resultsFileFormat_RESULTS_FILE_STANDARD)}
        ( standard {N_ifm(type,resultsFileFormat_RESULTS_FILE_STANDARD)}
          [ labeled {N_ifm(true,dakotaResultsFileLabeled)} ]
         )
        |
        json {N_ifm(type,resultsFileFormat_RESULTS_FILE_JSON)}
       ]
      [ file_tag {N_ifm(true,fileTagFlag)} ]
      [ file_save {N_ifm(true,fileSaveFlag)} ]
      [ work_directory {N_ifm(true,useWorkdir)}
        [ named {N_ifm(str,workDir)} ]
        [ directory_tag {N_ifm(true,dirTag)} ]
        [ directory_save {N_ifm(true,dirSave)} ]
        [ link_files {N_ifm(strL,linkFiles)} ]
        [ copy_files {N_ifm(strL,copyFiles)} ]
        [ replace {N_ifm(true,templateReplace)} ]
       ]
      [ allow_existing_results {N_ifm(true,allowExistingResultsFlag)} ]
      [ verbatim {N_ifm(true,verbatimFlag)} ]
     )
    |
    ( fork {N_ifm(type,interfaceType_FORK_INTERFACE)}
      [ parameters_file {N_ifm(str,parametersFile)} ]
      [ results_file {N_ifm(str,resultsFile)} ]
      [ parameters_format {N_ifm(type,parametersFileFormat_PARAMETERS_FILE_STANDARD)}
        standard {N_ifm(type,parametersFileFormat_PARAMETERS_FILE_STANDARD)}
        |
        aprepro {N_ifm(type,parametersFileFormat_PARAMETERS_FILE_APREPRO)}
        |
        json {N_ifm(type,parametersFileFormat_PARAMETERS_FILE_JSON)}
       ]
      [ results_format {N_ifm(type,resultsFileFormat_RESULTS_FILE_STANDARD)}
        ( standard {N_ifm(type,resultsFileFormat_RESULTS_FILE_STANDARD)}
          [ labeled {N_ifm(true,dakotaResultsFileLabeled)} ]
         )
        |
        json {N_ifm(type,resultsFileFormat_RESULTS_FILE_JSON)}
       ]
      [ file_tag {N_ifm(true,fileTagFlag)} ]
      [ file_save {N_ifm(true,fileSaveFlag)} ]
      [ work_directory {N_ifm(true,useWorkdir)}
        [ named {N_ifm(str,workDir)} ]
        [ directory_tag {N_ifm(true,dirTag)} ]
        [ directory_save {N_ifm(true,dirSave)} ]
        [ link_files {N_ifm(strL,linkFiles)} ]
        [ copy_files {N_ifm(strL,copyFiles)} ]
        [ replace {N_ifm(true,templateReplace)} ]
       ]
      [ allow_existing_results {N_ifm(true,allowExistingResultsFlag)} ]
      [ verbatim {N_ifm(true,verbatimFlag)} ]
     )
    |
    ( direct {N_ifm(type,interfaceType_TEST_INTERFACE)}
      [ processors_per_analysis {N_ifm(int,procsPerAnalysis)} ]
     )
    |
    ( plugin {N_ifm(type,interfaceType_PLUGIN_INTERFACE)}
      library_path {N_ifm(str,pluginLibraryPath)}
     )
    |
    matlab {N_ifm(type,interfaceType_MATLAB_INTERFACE)}
    |
    ( python {N_ifm(type,interfaceType_PYTHON_INTERFACE)}
      [ numpy {N_ifm(true,numpyFlag)} ]
     )
    |
    scilab {N_ifm(type,interfaceType_SCILAB_INTERFACE)}
    |
    grid {N_ifm(type,interfaceType_GRID_INTERFACE)}
    [ analysis_components {N_ifm(str2D,analysisComponents)} ]
   ]
  [ algebraic_mappings {N_ifm(str,algebraicMappings)} ]
  [ failure_capture {0}
    abort {N_ifm(lit,failAction_abort)}
    |
    retry {N_ifm(ilit,TYPE_DATA_failAction_retry)}
    |
    recover {N_ifm(Rlit,TYPE_DATA_failAction_recover)}
    |
    continuation {N_ifm(lit,failAction_continuation)}
   ]
  [ deactivate {0}
    [ active_set_vector {N_ifm(false,activeSetVectorFlag)} ]
    [ evaluation_cache {N_ifm(false,evalCacheFlag)} ]
    [ strict_cache_equality {N_ifm(true,nearbyEvalCacheFlag)}
      [ cache_tolerance {N_ifm(Real,nearbyEvalCacheTol)} ]
     ]
    [ restart_file {N_ifm(false,restartFileFlag)} ]
   ]
  [ 
    ( batch {N_ifm(true,batchEvalFlag)}
      [ size {N_ifm(int,asynchLocalEvalConcurrency)} ]
     )
    |
    ( asynchronous {N_ifm(true, asynchFlag)}
      [ evaluation_concurrency {N_ifm(int,asynchLocalEvalConcurrency)} ]
      [ local_evaluation_scheduling {0}
        dynamic {N_ifm(type,asynchLocalEvalScheduling_DYNAMIC_SCHEDULING)}
        |
        static {N_ifm(type,asynchLocalEvalScheduling_STATIC_SCHEDULING)}
       ]
      [ analysis_concurrency {N_ifm(int,asynchLocalAnalysisConcurrency)} ]
     )
   ]
  [ evaluation_servers {N_ifm(int,evalServers)} ]
  [ evaluation_scheduling {0}
    dedicated {N_ifm(type,evalScheduling_DEDICATED_SCHEDULER_DYNAMIC)}
    |
    ( peer {0}
      dynamic {N_ifm(type,evalScheduling_PEER_DYNAMIC_SCHEDULING)}
      |
      static {N_ifm(type,evalScheduling_PEER_STATIC_SCHEDULING)}
     )
   ]
  [ processors_per_evaluation {N_ifm(int,procsPerEval)} ]
  [ analysis_servers {N_ifm(int,analysisServers)} ]
  [ analysis_scheduling {0}
    dedicated {N_ifm(type,analysisScheduling_DEDICATED_SCHEDULER_DYNAMIC)}
    |
    peer {N_ifm(type,analysisScheduling_PEER_SCHEDULING)}
   ]

KEYWORD responses {N_rem3(start,0,stop)}
  [ id_responses {N_rem(str,idResponses)} ]
  [ descriptors {N_rem(strL,responseLabels)} ]
  ( objective_functions {N_rem(sizet,numObjectiveFunctions)}
    [ sense {N_rem(strL,primaryRespFnSense)} ]
    [ primary_scale_types {N_rem(strL,primaryRespFnScaleTypes)} ]
    [ primary_scales {N_rem(RealDL,primaryRespFnScales)} ]
    [ weights {N_rem(RealDL,primaryRespFnWeights)} ]
    [ nonlinear_inequality_constraints {N_rem(sizet,numNonlinearIneqConstraints)}
      [ lower_bounds {N_rem(RealDL,nonlinearIneqLowerBnds)} ]
      [ upper_bounds {N_rem(RealDL,nonlinearIneqUpperBnds)} ]
      [ scale_types {N_rem(strL,nonlinearIneqScaleTypes)} ]
      [ scales {N_rem(RealDL,nonlinearIneqScales)} ]
     ]
    [ nonlinear_equality_constraints {N_rem(sizet,numNonlinearEqConstraints)}
      [ targets {N_rem(RealDL,nonlinearEqTargets)} ]
      [ scale_types {N_rem(strL,nonlinearEqScaleTypes)} ]
      [ scales {N_rem(RealDL,nonlinearEqScales)} ]
     ]
    [ scalar_objectives {N_rem(sizet,numScalarObjectiveFunctions)} ]
    [ field_objectives {N_rem(sizet,numFieldObjectiveFunctions)}
      lengths {N_rem(ivec,fieldLengths)}
      [ num_coordinates_per_field {N_rem(ivec,numCoordsPerField)} ]
      [ read_field_coordinates {N_rem(true,readFieldCoords)} ]
     ]
   )
  |
  ( calibration_terms {N_rem(sizet,numLeastSqTerms)}
    [ scalar_calibration_terms {N_rem(sizet,numScalarLeastSqTerms)} ]
    [ field_calibration_terms {N_rem(sizet,numFieldLeastSqTerms)}
      lengths {N_rem(ivec,fieldLengths)}
      [ num_coordinates_per_field {N_rem(ivec,numCoordsPerField)} ]
      [ read_field_coordinates {N_rem(true,readFieldCoords)} ]
     ]
    [ primary_scales {N_rem(RealDL,primaryRespFnScales)} ]
    [ weights {N_rem(RealDL,primaryRespFnWeights)} ]
    [ 
      ( calibration_data {N_rem(true,calibrationDataFlag)}
        [ data_directory {N_rem(str,dataPathPrefix)} ]
        [ num_experiments {N_rem(sizet,numExperiments)} ]
        [ num_config_variables {N_rem(sizet,numExpConfigVars)} ]
        [ experiment_variance_type {N_rem(strL,varianceType)} ]
        [ scalar_data_file {N_rem(str,scalarDataFileName)}
          [ 
            ( custom_annotated {N_rem(utype,scalarDataFormat_TABULAR_NONE)}
              [ header {N_rem(augment_utype,scalarDataFormat_TABULAR_HEADER)} ]
              [ exp_id {N_rem(augment_utype,scalarDataFormat_TABULAR_EVAL_ID)} ]
             )
            |
            annotated {N_rem(utype,scalarDataFormat_TABULAR_EXPER_ANNOT)}
            |
            freeform {N_rem(utype,scalarDataFormat_TABULAR_NONE)}
           ]
         ]
        [ interpolate {N_rem(true,interpolateFlag)} ]
       )
      |
      ( calibration_data_file {N_rem(str,scalarDataFileName)}
        [ 
          ( custom_annotated {N_rem(utype,scalarDataFormat_TABULAR_NONE)}
            [ header {N_rem(augment_utype,scalarDataFormat_TABULAR_HEADER)} ]
            [ exp_id {N_rem(augment_utype,scalarDataFormat_TABULAR_EVAL_ID)} ]
           )
          |
          annotated {N_rem(utype,scalarDataFormat_TABULAR_EXPER_ANNOT)}
          |
          freeform {N_rem(utype,scalarDataFormat_TABULAR_NONE)}
         ]
        [ num_experiments {N_rem(sizet,numExperiments)} ]
        [ num_config_variables {N_rem(sizet,numExpConfigVars)} ]
        [ experiment_variance_type {N_rem(strL,varianceType)} ]
       )
     ]
    [ simulation_variance {N_rem(RealL,simVariance)} ]
    [ nonlinear_inequality_constraints {N_rem(sizet,numNonlinearIneqConstraints)}
      [ lower_bounds {N_rem(RealDL,nonlinearIneqLowerBnds)} ]
      [ upper_bounds {N_rem(RealDL,nonlinearIneqUpperBnds)} ]
      [ scale_types {N_rem(strL,nonlinearIneqScaleTypes)} ]
      [ scales {N_rem(RealDL,nonlinearIneqScales)} ]
     ]
    [ nonlinear_equality_constraints {N_rem(sizet,numNonlinearEqConstraints)}
      [ targets {N_rem(RealDL,nonlinearEqTargets)} ]
      [ scale_types {N_rem(strL,nonlinearEqScaleTypes)} ]
      [ scales {N_rem(RealDL,nonlinearEqScales)} ]
     ]
   )
  |
  ( response_functions {N_rem(sizet,numResponseFunctions)}
    [ scalar_responses {N_rem(sizet,numScalarResponseFunctions)} ]
    [ field_responses {N_rem(sizet,numFieldResponseFunctions)}
      lengths {N_rem(ivec,fieldLengths)}
      [ num_coordinates_per_field {N_rem(ivec,numCoordsPerField)} ]
      [ read_field_coordinates {N_rem(true,readFieldCoords)} ]
     ]
   )
  no_gradients {N_rem(lit,gradientType_none)}
  |
  analytic_gradients {N_rem(lit,gradientType_analytic)}
  |
  ( mixed_gradients {N_rem(lit,gradientType_mixed)}
    id_numerical_gradients {N_rem(intset,idNumericalGrads)}
    id_analytic_gradients {N_rem(intset,idAnalyticGrads)}
    [ method_source {0} ]
    [ 
      ( dakota {N_rem(lit,methodSource_dakota)}
        [ ignore_bounds {N_rem(true,ignoreBounds)} ]
        [ 
          relative {N_rem(lit,fdGradStepType_relative)}
          |
          absolute {N_rem(lit,fdGradStepType_absolute)}
          |
          bounds {N_rem(lit,fdGradStepType_bounds)}
         ]
       )
      |
      vendor {N_rem(lit,methodSource_vendor)}
     ]
    [ interval_type {0} ]
    [ 
      forward {N_rem(lit,intervalType_forward)}
      |
      central {N_rem(lit,intervalType_central)}
     ]
    [ fd_step_size {N_rem(RealL,fdGradStepSize)} ]
   )
  |
  ( numerical_gradients {N_rem(lit,gradientType_numerical)}
    [ method_source {0} ]
    [ 
      ( dakota {N_rem(lit,methodSource_dakota)}
        [ ignore_bounds {N_rem(true,ignoreBounds)} ]
        [ 
          relative {N_rem(lit,fdGradStepType_relative)}
          |
          absolute {N_rem(lit,fdGradStepType_absolute)}
          |
          bounds {N_rem(lit,fdGradStepType_bounds)}
         ]
       )
      |
      vendor {N_rem(lit,methodSource_vendor)}
     ]
    [ interval_type {0} ]
    [ 
      forward {N_rem(lit,intervalType_forward)}
      |
      central {N_rem(lit,intervalType_central)}
     ]
    [ fd_step_size {N_rem(RealL,fdGradStepSize)} ]
   )
  no_hessians {N_rem(lit,hessianType_none)}
  |
  ( numerical_hessians {N_rem(lit,hessianType_numerical)}
    [ fd_step_size {N_rem(RealL,fdHessStepSize)} ]
    [ 
      relative {N_rem(lit,fdHessStepType_relative)}
      |
      absolute {N_rem(lit,fdHessStepType_absolute)}
      |
      bounds {N_rem(lit,fdHessStepType_bounds)}
     ]
    [ 
      forward {N_rem(false,centralHess)}
      |
      central {N_rem(true,centralHess)}
     ]
   )
  |
  ( quasi_hessians {N_rem(lit,hessianType_quasi)}
    ( bfgs {N_rem(lit,quasiHessianType_bfgs)}
      [ damped {N_rem(lit,quasiHessianType_damped_bfgs)} ]
     )
    |
    sr1 {N_rem(lit,quasiHessianType_sr1)}
   )
  |
  analytic_hessians {N_rem(lit,hessianType_analytic)}
  |
  ( mixed_hessians {N_rem(lit,hessianType_mixed)}
    [ id_numerical_hessians {N_rem(intset,idNumericalHessians)}
      [ fd_step_size {N_rem(RealL,fdHessStepSize)} ]
     ]
    [ 
      relative {N_rem(lit,fdHessStepType_relative)}
      |
      absolute {N_rem(lit,fdHessStepType_absolute)}
      |
      bounds {N_rem(lit,fdHessStepType_bounds)}
     ]
    [ 
      forward {N_rem(false,centralHess)}
      |
      central {N_rem(true,centralHess)}
     ]
    [ id_quasi_hessians {N_rem(intset,idQuasiHessians)}
      ( bfgs {N_rem(lit,quasiHessianType_bfgs)}
        [ damped {N_rem(lit,quasiHessianType_damped_bfgs)} ]
       )
      |
      sr1 {N_rem(lit,quasiHessianType_sr1)}
     ]
    [ id_analytic_hessians {N_rem(intset,idAnalyticHessians)} ]
   )
  [ metadata {N_rem(strL,metadataLabels)} ]

