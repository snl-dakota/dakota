# DAKOTA INPUT FILE - dakota_uq_textbook_adaptsampling_async.in
# Variant of dakota_uq_textbook_adaptsampling.in that exercises
# asynchronous batch evaluation in the adaptive sampling loop.

method,
        adaptive_sampling,
          initial_samples = 20
          seed = 1234

          response_levels =  10.0
          samples_on_emulator = 400
          max_iterations = 50
          refinement_samples = 2
          batch_selection = naive
          fitness_metric = predicted_variance

variables,
        uniform_uncertain = 2
          descriptors  = 'x1' 'x2'
          lower_bounds =  -2.0   -2.0
          upper_bounds =  2.0   2.0

interface,
        direct
          analysis_driver = 'text_book'
          asynchronous evaluation_concurrency = 4

responses,
        response_functions = 1
        no_gradients
        no_hessians
